[flake8]
max-line-length = 100
exclude = 
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache
ignore = 
    E203,  # whitespace before ':'
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
    W605,  # invalid escape sequence
    E402,  # module level import not at top of file
per-file-ignores =
    __init__.py:F401
    tests/*.py:F401,F811